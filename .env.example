# ==== Database (PostgreSQL) ====
# Local (contoh): postgresql://postgres:postgres@localhost:5432/kasirkopi
# Vercel Postgres / Neon / Supabase: salin "connection string" nya ke sini.
DATABASE_URL="postgresql://user:password@localhost:5432/kasirkopi?schema=public"

# ==== QRIS via Midtrans (DIREKOMENDASIKAN — notifikasi bayar otomatis) ====
# Daftar di https://midtrans.com (sandbox gratis). Ambil Server Key di
# Dashboard > Settings > Access Keys. Bila diisi, aplikasi memakai QRIS Midtrans
# dan status transaksi update OTOMATIS via webhook.
# Set Payment Notification URL di dashboard Midtrans ke:
#   https://<domain-anda>/api/midtrans/notification
MIDTRANS_SERVER_KEY=""
# "true" untuk mode produksi, kosong/"false" untuk sandbox.
MIDTRANS_IS_PRODUCTION="false"

# ==== QRIS statis (fallback bila MIDTRANS_SERVER_KEY kosong) ====
# String QRIS STATIS milik merchant Anda (hasil decode QR statis dari penyedia,
# mis. dari GoPay Merchant / QRIS dari bank). Aplikasi akan meng-convert
# otomatis menjadi QRIS DINAMIS (menyisipkan nominal transaksi) yang bisa
# dibayar via aplikasi bank / e-wallet apa pun.
#
# Kosongkan untuk memakai contoh demo (QR akan valid format tapi bukan rekening asli).
QRIS_MERCHANT_STRING=""

# Nama merchant yang tampil di struk
NEXT_PUBLIC_STORE_NAME="KasirKopi"
